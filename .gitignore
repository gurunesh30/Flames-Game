# ----------------------------------------
# PYTHON SPECIFIC FILES
# ----------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
env/
.venv/
.pip/
config.js
# Distribution / packaging
.Python
build/
develop-eggs/
dist/
eggs/
lib/
lib64/

# ----------------------------------------
# OS & EDITOR FILES
# ----------------------------------------
.DS_Store # macOS junk files
.vscode/  # VS Code config (optional, but good for clean repos)
*.swp     # Vim swap files
*~        # Temporary files

# ----------------------------------------
# SENSITIVE DATA & LOCAL CONFIGS
# ----------------------------------------
# This is CRITICAL. Your database passwords are here.
config.json
*.env
.secrets
# If you created a separate config file for MySQL, list it here
# e.g., db_config.py


# ----------------------------------------
# JAVASCRIPT / NODE SPECIFIC
# ----------------------------------------
node_modules/
bower_components/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
build/
dist/
.next/
out/